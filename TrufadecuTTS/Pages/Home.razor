@page "/"
@using TrufadecuTTS.Services
@inject ITtsService TtsService
@inject IJSRuntime JSRuntime

<PageTitle>Google Cloud Text-to-Speech</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-volume-up-fill me-2"></i>
                        Google Cloud Text-to-Speech
                    </h3>
                    <small>Advanced text-to-speech synthesis with all features at your fingertips</small>
                </div>
                <div class="card-body">
                    @if (showApiKeyWarning)
                    {
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>API Configuration Required!</strong> To use the Google Cloud Text-to-Speech API, you need to configure your credentials.
                            <a href="/config" class="alert-link">Go to Configuration</a>
                            <button type="button" class="btn-close" @onclick="() => showApiKeyWarning = false"></button>
                        </div>
                    }

                    <div class="row">
                        <!-- Text Input Section -->
                        <div class="col-lg-8">
                            <div class="mb-4">
                                <label for="textInput" class="form-label fw-bold">
                                    <i class="bi bi-textarea-t me-1"></i>Text to Synthesize
                                </label>
                                <textarea @bind="ttsRequest.Text" 
                                          class="form-control" 
                                          id="textInput" 
                                          rows="6" 
                                          placeholder="Enter the text you want to convert to speech..."
                                          maxlength="5000"></textarea>
                                <div class="form-text">
                                    Character count: @ttsRequest.Text.Length / 5000
                                </div>
                            </div>

                            <!-- Audio Controls -->
                            <div class="mb-4">
                                <h5><i class="bi bi-sliders me-2"></i>Audio Controls</h5>
                                <div class="row">
                                    <div class="col-md-4">
                                        <label class="form-label">Speaking Rate</label>
                                        <input type="range" @bind="ttsRequest.SpeakingRate" 
                                               class="form-range" 
                                               min="0.25" max="4.0" step="0.1">
                                        <div class="form-text">@ttsRequest.SpeakingRate.ToString("F1")x</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Pitch</label>
                                        <input type="range" @bind="ttsRequest.Pitch" 
                                               class="form-range" 
                                               min="-20.0" max="20.0" step="0.5">
                                        <div class="form-text">@ttsRequest.Pitch.ToString("F1") Hz</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Volume Gain</label>
                                        <input type="range" @bind="ttsRequest.VolumeGainDb" 
                                               class="form-range" 
                                               min="-96.0" max="16.0" step="1">
                                        <div class="form-text">@ttsRequest.VolumeGainDb.ToString("F0") dB</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-flex gap-2 mb-4">
                                <button class="btn btn-primary btn-lg" 
                                        @onclick="SynthesizeText" 
                                        disabled="@(isLoading || string.IsNullOrWhiteSpace(ttsRequest.Text))">
                                    @if (isLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-play-fill me-2"></i>
                                    }
                                    Generate Speech
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="ClearAll">
                                    <i class="bi bi-arrow-clockwise me-2"></i>Clear All
                                </button>
                                <button class="btn btn-outline-info" @onclick="LoadSampleText">
                                    <i class="bi bi-file-text me-2"></i>Load Sample
                                </button>
                            </div>

                            <!-- Audio Player -->
                            @if (audioData != null)
                            {
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6><i class="bi bi-music-note-beamed me-2"></i>Generated Audio</h6>
                                        <audio controls class="w-100" src="@audioDataUrl">
                                            Your browser does not support the audio element.
                                        </audio>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Voice Selection Section -->
                        <div class="col-lg-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="mb-0"><i class="bi bi-person-voice me-2"></i>Voice Configuration</h5>
                                </div>
                                <div class="card-body">
                                    <!-- Language Selection -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Language</label>
                                        <select @bind="ttsRequest.LanguageCode" class="form-select">
                                            <option value="en-US">English (US)</option>
                                            <option value="pt-BR">Portuguese (Brazil)</option>
                                            <option value="es-ES">Spanish (Spain)</option>
                                            <option value="fr-FR">French (France)</option>
                                            <option value="de-DE">German (Germany)</option>
                                            <option value="ja-JP">Japanese (Japan)</option>
                                            <option value="ko-KR">Korean (Korea)</option>
                                        </select>
                                    </div>

                                    <!-- Voice Selection -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Voice</label>
                                        <select @bind="ttsRequest.VoiceName" class="form-select">
                                            <option value="">Auto-select best voice</option>
                                            @foreach (var voice in filteredVoices)
                                            {
                                                <option value="@voice.Name">
                                                    @voice.Name (@voice.Gender)
                                                </option>
                                            }
                                        </select>
                                        <div class="form-text">
                                            @filteredVoices.Count voices available for @ttsRequest.LanguageCode
                                        </div>
                                    </div>

                                    <!-- Gender Selection -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Preferred Gender</label>
                                        <select @bind="ttsRequest.Gender" class="form-select">
                                            <option value="NEUTRAL">Neutral</option>
                                            <option value="FEMALE">Female</option>
                                            <option value="MALE">Male</option>
                                        </select>
                                    </div>

                                    <!-- Audio Format -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Audio Format</label>
                                        <select @bind="ttsRequest.AudioEncoding" class="form-select">
                                            <option value="MP3">MP3</option>
                                            <option value="WAV">WAV</option>
                                            <option value="OGG_OPUS">OGG Opus</option>
                                            <option value="MULAW">μ-law</option>
                                            <option value="ALAW">A-law</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Quick Settings -->
                            <div class="card mt-3">
                                <div class="card-header">
                                    <h6 class="mb-0"><i class="bi bi-lightning-fill me-2"></i>Quick Presets</h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-outline-primary btn-sm" @onclick="@(() => ApplyPreset("normal"))">
                                            <i class="bi bi-person me-1"></i>Normal Speech
                                        </button>
                                        <button class="btn btn-outline-success btn-sm" @onclick="@(() => ApplyPreset("slow"))">
                                            <i class="bi bi-arrow-down me-1"></i>Slow &amp; Clear
                                        </button>
                                        <button class="btn btn-outline-warning btn-sm" @onclick="@(() => ApplyPreset("fast"))">
                                            <i class="bi bi-arrow-up me-1"></i>Fast Speech
                                        </button>
                                        <button class="btn btn-outline-info btn-sm" @onclick="@(() => ApplyPreset("deep"))">
                                            <i class="bi bi-arrow-down-circle me-1"></i>Deep Voice
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => ApplyPreset("high"))">
                                            <i class="bi bi-arrow-up-circle me-1"></i>High Voice
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private TtsRequest ttsRequest = new();
    private bool isLoading = false;
    private bool showApiKeyWarning = true;
    private List<VoiceInfo> availableVoices = new();
    private byte[]? audioData;
    private string? audioDataUrl;

    private List<VoiceInfo> filteredVoices => 
        availableVoices.Where(v => v.LanguageCode == ttsRequest.LanguageCode).ToList();

    protected override async Task OnInitializedAsync()
    {
        // Load available voices
        availableVoices = await TtsService.GetAvailableVoicesAsync();
        
        // Set default text
        ttsRequest.Text = "Welcome to Google Cloud Text-to-Speech! This is a demonstration of the powerful speech synthesis capabilities.";
    }

    private async Task SynthesizeText()
    {
        if (string.IsNullOrWhiteSpace(ttsRequest.Text))
            return;

        isLoading = true;
        audioData = null;
        audioDataUrl = null;

        try
        {
            audioData = await TtsService.SynthesizeTextAsync(ttsRequest);
            
            if (audioData != null)
            {
                // Convert audio data to data URL for playback
                var base64Audio = Convert.ToBase64String(audioData);
                var mimeType = ttsRequest.AudioEncoding.ToLower() switch
                {
                    "mp3" => "audio/mpeg",
                    "wav" => "audio/wav",
                    "ogg_opus" => "audio/ogg",
                    _ => "audio/mpeg"
                };
                audioDataUrl = $"data:{mimeType};base64,{base64Audio}";
            }
            else
            {
                // Show message about server implementation needed
                await JSRuntime.InvokeVoidAsync("alert", 
                    "To enable audio synthesis, you need to implement the server-side Google Cloud TTS integration. " +
                    "This interface shows all the available features and parameters you can use with the Google Cloud Text-to-Speech API.");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearAll()
    {
        ttsRequest = new TtsRequest();
        audioData = null;
        audioDataUrl = null;
    }

    private void LoadSampleText()
    {
        ttsRequest.Text = "Google Cloud Text-to-Speech enables developers to synthesize natural-sounding speech with over 380 voices, available in 50+ languages and variants. It offers advanced features like custom voice models, audio profiles, and real-time streaming. Whether you're building voice assistants, reading applications, or accessibility tools, Google Cloud TTS provides the flexibility and quality you need.";
    }

    private void ApplyPreset(string preset)
    {
        switch (preset)
        {
            case "normal":
                ttsRequest.SpeakingRate = 1.0;
                ttsRequest.Pitch = 0.0;
                ttsRequest.VolumeGainDb = 0.0;
                break;
            case "slow":
                ttsRequest.SpeakingRate = 0.7;
                ttsRequest.Pitch = -2.0;
                ttsRequest.VolumeGainDb = 3.0;
                break;
            case "fast":
                ttsRequest.SpeakingRate = 1.5;
                ttsRequest.Pitch = 1.0;
                ttsRequest.VolumeGainDb = 0.0;
                break;
            case "deep":
                ttsRequest.SpeakingRate = 0.9;
                ttsRequest.Pitch = -10.0;
                ttsRequest.VolumeGainDb = 2.0;
                break;
            case "high":
                ttsRequest.SpeakingRate = 1.1;
                ttsRequest.Pitch = 8.0;
                ttsRequest.VolumeGainDb = -2.0;
                break;
        }
    }
}
